# AI Provider 設定（擇一填入）
ANTHROPIC_API_KEY=sk-ant-xxxxxx
#OPENAI_API_KEY=sk-xxxxxx

# 使用的 AI provider：anthropic 或 openai（預設 anthropic）
#AI_PROVIDER=anthropic

# 伺服器設定
#PORT=3000

# CORS：前端部署後填入 Vercel 網址（多個用逗號分隔，或保持 * 允許全部）
# 例如：CORS_ORIGIN=https://your-app.vercel.app
#CORS_ORIGIN=*

# 靜態檔案目錄（本地開發前後端合一時使用）
#STATIC_DIR=public
