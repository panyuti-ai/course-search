# AI Provider 設定（擇一填入）
ANTHROPIC_API_KEY=sk-ant-xxxxxx
#OPENAI_API_KEY=sk-xxxxxx
# OpenRouter 可使用 OpenAI-compatible 設定
#OPENAI_API_KEY=sk-or-v1-xxxxxx
#OPENAI_BASE_URL=https://openrouter.ai/api/v1
#OPENAI_MODEL=openai/gpt-4o-mini

# 使用的 AI provider：anthropic 或 openai（預設 anthropic）
#AI_PROVIDER=anthropic

# 伺服器設定
#PORT=3000

# CORS：前端部署後填入 Vercel 網址（多個用逗號分隔，或保持 * 允許全部）
# 例如：CORS_ORIGIN=https://your-app.vercel.app
#CORS_ORIGIN=*

# 靜態檔案目錄（本地開發前後端合一時使用）
#STATIC_DIR=public

# NID OAuth 設定
NID_CLIENT_ID=639113396662.9a12201d531d490f870468b48ca9ce99.fcu-coursesearch.com
NID_CALLBACK_URL=https://fcu-coursesearch.com/callback
# JWT 簽名密鑰（請換成隨機長字串）
JWT_SECRET=your-random-secret-here
